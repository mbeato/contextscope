# Copy to .env.publish and fill in the token. .env.publish is gitignored.
#
# Generate at: https://www.npmjs.com/settings/<your-user>/tokens
#   - Type: Granular Access Token
#   - Packages and scopes: only `tokenscope`
#   - Permissions: Read and write
#   - Enable: "Bypass two-factor authentication"
NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
